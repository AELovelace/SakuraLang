    style Respond fill:#b3d9ff,stroke:#6699cc,color:#000
    style Hybrid fill:#fff3cd,stroke:#cc9900,color:#000
    style Rerank fill:#ffe0b3,stroke:#cc9966,color:#000
    style SmallBig fill:#ffe0b3,stroke:#cc9966,color:#000
    style Compress fill:#ffe0b3,stroke:#cc9966,color:#000
    style Context fill:#b3ffcc,stroke:#66cc88,color:#000
    style Chunking fill:#eeeeee,stroke:#999999,color:#000
