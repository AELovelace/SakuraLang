---
title: SakuraLang — Hybrid RAG Pipeline (rag.py)
---
flowchart TD
    User(["User request"]) --> Classify["classify node\nrag_needed = true"]
    Classify --> Rewrite["Query rewrite (Qwen)\nraw prompt → keyword-rich search query\nkeeps IDs / codes / IPs / PLUs verbatim"]

    Rewrite --> Ensure{"index fresh?\n(signature check)"}
    Ensure -->|"stale / missing"| Build["BUILD\nwalk cwd → chunk by file type\nsmall children + parent sections\nembed → Qdrant • index → BM25"]
    Ensure -->|"unchanged"| Load["LOAD persisted index\n.sakura_rag/ (no re-embed)"]
    Build --> Retrieve
    Load --> Retrieve

    subgraph Hybrid["Hybrid retrieval"]
        direction LR
        Dense["Dense / vector\nbge-small embeddings\ntop 20"]
        Sparse["Sparse / BM25\nkeyword match\ntop 20"]
        Dense --> Fuse["RRF fusion\nreciprocal rank fusion"]
        Sparse --> Fuse
    end

    Retrieve["retrieve(query)"] --> Hybrid
    Fuse --> Rerank["Rerank\nCrossEncoder ms-marco-MiniLM\ntop 20 → top 5"]
    Rerank --> SmallBig["Small-to-big\nswap matched child chunk\nfor its parent section"]
    SmallBig --> Compress["Compress\ngreedily pack parents\n≤ ~1500 tokens"]
    Compress --> Context[["rag_context"]]

    Context --> Respond["respond node\nQwen answers grounded\nONLY in retrieved context"]
    Respond --> Answer(["Answer + sources"])

    %% chunking note
    Chunking["Chunk size by type:\nmanuals 500–900 tok • logs 50–200 lines\nconfigs per section • code per fn/class\nCSV/inventory per entity"]
    Build -.-> Chunking

    style User fill:#ffb7c5,stroke:#cc7088,color:#000
    style Answer fill:#ffb7c5,stroke:#cc7088,color:#000
